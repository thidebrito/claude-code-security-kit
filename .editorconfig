# EditorConfig — consistent coding styles across editors
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false  # markdown allows trailing 2 spaces for line break

[*.{sh,bash}]
indent_size = 2

[*.{py}]
indent_size = 4

[Makefile]
indent_style = tab
