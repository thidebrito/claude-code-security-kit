# ═══════════════════════════════════════════════════════════════
# .env.example — TEMPLATE de variáveis de ambiente
# Copie pra .env (que nunca é commitado) e preencha com valores reais
# ═══════════════════════════════════════════════════════════════

# === Supabase (se aplicável) ============================
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=     # NUNCA expor no frontend

# === Hotmart (se aplicável) =============================
# HOTMART_CLIENT_ID=
# HOTMART_CLIENT_SECRET=
# HOTMART_BASIC_TOKEN=
# HOTMART_WEBHOOK_TOKEN=

# === Resend (transactional email) =======================
# RESEND_API_KEY=

# === Meta Ads / Pixel ===================================
# META_PIXEL_ID=YOUR_META_PIXEL_ID
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# === Google Ads ========================================
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_MCC_CUSTOMER_ID=
# GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_REFRESH_TOKEN=

# === OpenTimestamps (Camada C) =========================
# OTS_CACHE_DIR=~/.ots-cache

# === Vercel (se usado em scripts locais) ===============
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_ORG_ID=

# === Outros =============================================
# NODE_ENV=development
# DEBUG=true
